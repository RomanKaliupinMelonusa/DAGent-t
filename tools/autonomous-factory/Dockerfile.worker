# =============================================================================
# Dockerfile.worker — Production worker container for the Temporal-backed
# DAGent orchestrator. Multi-stage: builder compiles TypeScript, runtime
# carries only the dist/ output + production node_modules.
#
# Build context expectation: the build is launched from the REPOSITORY ROOT
# so the entire monorepo (apps/, scripts/, tools/) is available. The
# postinstall ajv shim (scripts/postinstall-ajv-shim.mjs, see Session 5
# decision D5-5) is a hard dependency — DO NOT use `npm ci --ignore-scripts`
# in any stage. Without the shim the workflow bundler crashes on first
# poll because eslint v9's ajv@v6 vs schema-utils' ajv-keywords@v8 conflict
# blows up at module-load time.
#
# Build:
#   docker build -f tools/autonomous-factory/Dockerfile.worker \
#                -t dagent/worker:<tag> .
#
# Boot:
#   docker run --rm \
#       -e TEMPORAL_ADDRESS=temporal:7233 \
#       -e TEMPORAL_TASK_QUEUE=dagent-default \
#       -e TEMPORAL_NAMESPACE=default \
#       -e APP_ROOT=/workspace/apps/sample-app \
#       -e WORKER_DISABLE_LLM=1 \
#       -e OTLP_ENDPOINT=http://otel-collector:4317 \
#       -v $(pwd):/workspace:ro \
#       dagent/worker:<tag>
#
# Environment variables consumed by the worker
# (defaults documented in src/temporal/worker/main.ts):
#   TEMPORAL_ADDRESS    — Temporal frontend gRPC address (default localhost:7233)
#   TEMPORAL_TASK_QUEUE — Task queue this worker polls (default dagent-hello)
#   TEMPORAL_NAMESPACE  — Temporal namespace (default default)
#   APP_ROOT            — Absolute path to the app directory (required for
#                         the LLM-backed activities; degraded mode when
#                         absent — see worker/main.ts).
#   WORKER_DISABLE_LLM  — "1" or "true" to skip CopilotClient startup;
#                         used by CI activity-smoke tests.
#   OTLP_ENDPOINT       — When set, wires the OTel-emitting PipelineLogger
#                         + activity-span exporter (Session 5 P5).
# =============================================================================

# ---- Stage 1: builder ---------------------------------------------------------
FROM node:22-bookworm-slim AS builder

WORKDIR /build

# Copy the lockfile-relevant files first for layer-cache friendliness.
# Workspace package.json lives at /tools/autonomous-factory/.
COPY package.json package-lock.json ./
COPY scripts/ ./scripts/
COPY tools/autonomous-factory/package.json ./tools/autonomous-factory/
COPY apps/sample-app/package.json ./apps/sample-app/
COPY apps/sample-app/backend/package.json ./apps/sample-app/backend/
COPY apps/sample-app/frontend/package.json ./apps/sample-app/frontend/

# Run a full workspace install so the postinstall ajv shim runs against
# the real lockfile state. Do NOT pass --ignore-scripts.
RUN npm ci

# Copy source — only what's needed to compile the orchestrator.
COPY tools/autonomous-factory/ ./tools/autonomous-factory/

# Compile TypeScript → dist/.
RUN cd tools/autonomous-factory && npm run temporal:build

# ---- Stage 2: runtime ---------------------------------------------------------
FROM node:22-bookworm-slim AS runtime

# Install only what's needed for healthchecks (curl) and a clean shutdown.
RUN apt-get update \
    && apt-get install --no-install-recommends -y curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Non-root user — Temporal worker has no need for root.
RUN groupadd --system --gid 1001 dagent \
    && useradd --system --uid 1001 --gid dagent --create-home --home-dir /home/dagent dagent

WORKDIR /app

# Copy compiled output + node_modules from builder. The shim files under
# /scripts/ are required at runtime (they don't run again, but the
# postinstall path resolves them transitively).
COPY --from=builder --chown=dagent:dagent /build/node_modules ./node_modules
COPY --from=builder --chown=dagent:dagent /build/scripts ./scripts
COPY --from=builder --chown=dagent:dagent /build/package.json ./package.json
COPY --from=builder --chown=dagent:dagent /build/tools/autonomous-factory/package.json ./tools/autonomous-factory/package.json
COPY --from=builder --chown=dagent:dagent /build/tools/autonomous-factory/dist ./tools/autonomous-factory/dist
COPY --from=builder --chown=dagent:dagent /build/tools/autonomous-factory/node_modules ./tools/autonomous-factory/node_modules

USER dagent
WORKDIR /app/tools/autonomous-factory

# Default env — overridable at run-time. WORKER_DISABLE_LLM defaults to
# 1 so the container boots in a billing-safe smoke mode unless the
# operator explicitly opts into the live SDK path.
ENV NODE_ENV=production \
    TEMPORAL_ADDRESS=localhost:7233 \
    TEMPORAL_TASK_QUEUE=dagent-default \
    TEMPORAL_NAMESPACE=default \
    WORKER_DISABLE_LLM=1

# Worker logs "[worker] connected to <addr>" once it has joined the task
# queue; integration tests grep for that line as the readiness signal.
CMD ["node", "dist/temporal/worker/main.js"]
