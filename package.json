{
  "name": "agentic-pipeline-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Deterministic agentic coding pipeline — DAG-scheduled AI agents from spec to PR",
  "workspaces": [
    "apps/**",
    "!apps/commerce-storefront",
    "!apps/commerce-storefront/**",
    "tools/*"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall-ajv-shim.mjs",
    "pipeline:init": "npx tsx tools/autonomous-factory/src/cli/pipeline-state.ts init",
    "pipeline:reset-scripts": "npx tsx tools/autonomous-factory/src/cli/pipeline-state.ts reset-scripts",
    "pipeline:status": "npx tsx tools/autonomous-factory/src/cli/pipeline-state.ts status",
    "pipeline:next": "npx tsx tools/autonomous-factory/src/cli/pipeline-state.ts next",
    "pipeline:resume": "npx tsx tools/autonomous-factory/src/cli/pipeline-state.ts resume",
    "pipeline:recover-elevated": "npx tsx tools/autonomous-factory/src/cli/pipeline-state.ts recover-elevated",
    "pipeline:recover-dangling": "npx tsx tools/autonomous-factory/src/cli/pipeline-state.ts recover-dangling",
    "pipeline:lineage": "npx tsx tools/autonomous-factory/src/cli/pipeline-lineage.ts",
    "pipeline:trace": "npx tsx tools/autonomous-factory/src/cli/pipeline-lineage.ts",
    "agent:commit": "bash tools/autonomous-factory/agent-commit.sh",
    "agent:branch": "bash tools/autonomous-factory/agent-branch.sh",
    "agent:run": "cd tools/autonomous-factory && npx tsx src/entry/watchdog.ts",
    "agent:run:detached": "bash scripts/run-agent.sh",
    "agent:supervise": "cd tools/autonomous-factory && npx tsx src/entry/supervise.ts",
    "arch:check": "node tools/autonomous-factory/scripts/arch-check.mjs",
    "pipeline:lint": "npx tsx tools/autonomous-factory/scripts/lint-pipeline.ts",
    "pipeline:viz": "npx tsx tools/autonomous-factory/scripts/viz-pipeline.ts",
    "apm:canvas": "npx tsx tools/autonomous-factory/scripts/export-canvas.ts",
    "build:instructions": "node tools/autonomous-factory/build-instructions.mjs",
    "retro": "cd tools/autonomous-factory && npx tsx src/reporting/retrospective.ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  },
  "overrides": {
    "fast-xml-parser": ">=5.5.6",
    "ajv-keywords": {
      "ajv": "^8.17.0"
    },
    "eslint": {
      "@eslint/eslintrc": {
        "ajv": "6.14.0"
      }
    }
  }
}
