{
  "name": "Agentic Pipeline Platform",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",

  "remoteEnv": {
    "NODE_VERSION": "22.15",
    "PATH": "/home/node/.temporalio/bin:${containerEnv:PATH}"
  },

  "runArgs": [
    "--shm-size=2gb",
    "--ipc=host",
    "--memory=16g"
  ],

  "mounts": [
    "source=agentic-pipeline-azure-cli,target=/home/node/.azure,type=volume"
  ],

  "features": {
    "ghcr.io/devcontainers/features/azure-cli:1": { "version": "2.73.0" },
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.11"
    }
  },

  "postCreateCommand": "sudo chown -R node:node /home/node/.azure && npm install && cd tools/autonomous-factory && npm install && cd ../.. && npx --yes playwright install --with-deps chromium && bash tools/autonomous-factory/setup-roam.sh && az extension add --name application-insights --yes 2>/dev/null && curl -sSf https://temporal.download/cli.sh | sh",

  "postStartCommand": "git config --global core.hooksPath tools/autonomous-factory/hooks",

  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "hashicorp.terraform",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-azurefunctions",
        "anthropic.claude-code"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "files.watcherExclude": {
          "**/.roam/**": true,
          "**/.dagent/**": true,
          "**/archive/**": true,
          "**/node_modules/**": true,
          "**/test-results/**": true
        },
        "search.exclude": {
          "**/.roam": true,
          "**/.dagent": true,
          "**/archive": true,
          "**/test-results": true
        }
      }
    }
  },

  "containerEnv": {
    "SHELL": "/bin/zsh",
    "ROAM_PYTHON": "/home/node/.roam-venv/bin/python"
  }
}
